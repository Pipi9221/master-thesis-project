# MR Experiment Prototype — Environment Configuration
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your local paths
#   source .env

# ============================================================================
# Required: External Tools
# ============================================================================

# --- Frama-C (C program slicer) ---
# Path to frama-c binary (default: frama-c, resolved from PATH)
FRAMA_BINARY=frama-c
# Extra args passed to frama-c before the input file
# FRAMA_ARGS=
# C compiler for MR1 value oracle (default: gcc)
# COMPILER_BINARY=gcc
# Extra compiler flags for observation programs
# COMPILER_ARGS=-Wall -Wextra

# --- DG / llvm-slicer (LLVM IR slicer) ---
# Path to llvm-slicer binary
DG_LLVM_SLICER_BINARY=/path/to/dg/build/tools/llvm-slicer
# Clang for seed→bitcode compilation (default: clang-14)
# DG_CLANG_BINARY=clang-14
# llvm-dis for disassembling sliced bitcode (default: llvm-dis-14)
# DG_LLVM_DIS_BINARY=llvm-dis-14
# lli for MR1 sliced program value observation (default: lli-14)
# DG_LLI_BINARY=lli-14
# llvm-link for MR1 observation helper linkage (default: llvm-link-14)
# DG_LLVM_LINK_BINARY=llvm-link-14
# Extra args passed to llvm-slicer (default: -annotate slice)
# DG_ARGS=-annotate slice

# --- CSmith (C program generator) ---
# CSmith installation root (must contain include/csmith.h and bin/csmith)
# CSMITH_HOME=/usr
# Extra flags passed to csmith (space-separated)
# CSMITH_USER_OPTIONS=--no-bitfields --max-block-depth 3 --max-block-size 4 --max-pointer-depth 2
# CSmith headers directory (default: /usr/include/csmith)
CSMITH_INCLUDE_DIR=/usr/include/csmith

# --- Creal (MR1 seed/mutant generator) ---
# Path to creal.py
CREAL_SCRIPT=/path/to/creal/creal.py
# Python interpreter for running Creal (default: /usr/bin/python3)
# CREAL_PYTHON=/usr/bin/python3

# --- mr_ast_tool (MR2/MR3 AST mutator) ---
# Build with: cmake -S tooling -B tooling/build && cmake --build tooling/build
MR_AST_TOOL_BIN=/path/to/project/tooling/build/mr_ast_tool

# --- Compile gate ---
# Clang binary for compile-check gate (default: /usr/lib/llvm-14/bin/clang)
# CLANG_BIN=/usr/lib/llvm-14/bin/clang

# ============================================================================
# Optional: LLM Integration
# ============================================================================

# --- LLM online seed generation ---
# Command template with {prompt_file} and {output_file} placeholders.
# Example using DeepSeek client:
#   LLM_COMMAND=python3 tooling/deepseek_client.py --prompt-file {prompt_file} --output-file {output_file}
# LLM_COMMAND=python3 tooling/deepseek_client.py --prompt-file {prompt_file} --output-file {output_file}

# --- LLM-assisted judge (DG hybrid/required mode) ---
# DG_JUDGE_MODE=off
# Command template for LLM judge ({bundle_json} placeholder):
# DG_LLM_JUDGE_COMMAND=python3 tooling/deepseek_judge.py --bundle {bundle_json} --output-dir /tmp/judge

# --- DeepSeek API (used by both seed generation and judge) ---
# API key for DeepSeek API
# DEEPSEEK_API_KEY=sk-your-key-here
# Base URL and model (defaults shown):
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-pro

# ============================================================================
# Optional: Bug Test Harnesses
# ============================================================================

# Path to DG experiments precision cases (test_dg_bugs.py, test_mr1_bug_detection.py)
# Default: ../dg-experiments/comfirm-issue/cases/precision relative to project
# DG_EXPERIMENTS_CASES=/path/to/dg-experiments/comfirm-issue/cases/precision

# Path to Frama-C bug database (test_frama_bugs.py)
# Default: ../bugs/frama relative to project
# FRAMA_BUGS_BASE=/path/to/project/bugs/frama
