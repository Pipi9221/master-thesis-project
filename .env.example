# MR Experiment Prototype — Environment Configuration
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your local paths
#   source .env
#
# All variables use "export" so subprocesses can see them.
# Uncomment any line and replace the placeholder path to activate it.
#
# IMPORTANT: Values containing spaces or special characters MUST be quoted.
#   Correct:   export COMPILER_ARGS="-Wall -Wextra"
#   Wrong:     export COMPILER_ARGS=-Wall -Wextra   (causes "command not found" errors)

# ============================================================================
# Required: External Tools
# ============================================================================

# --- Frama-C (C program slicer) ---
# Path to frama-c binary (default: frama-c, resolved from PATH)
export FRAMA_BINARY=frama-c
# Extra args passed to frama-c before the input file
# export FRAMA_ARGS=""
# C compiler for MR1 value oracle (default: gcc)
# export COMPILER_BINARY=gcc
# Extra compiler flags for observation programs
# export COMPILER_ARGS="-Wall -Wextra"
# Extra linker flags for observation programs (default: -lm)
# export LINK_ARGS="-lm"

# --- DG / llvm-slicer (LLVM IR slicer) ---
# Path to llvm-slicer binary
export DG_LLVM_SLICER_BINARY=/path/to/dg/build/tools/llvm-slicer
# DG installation root (optional, auto-detected from DG_LLVM_SLICER_BINARY)
# export DG_HOME=/path/to/dg
# Clang for seed→bitcode compilation (default: clang-14)
# export DG_CLANG_BINARY=clang-14
# llvm-dis for disassembling sliced bitcode (default: llvm-dis-14)
# export DG_LLVM_DIS_BINARY=llvm-dis-14
# lli for MR1 sliced program value observation (default: lli-14)
# export DG_LLI_BINARY=lli-14
# llvm-link for MR1 observation helper linkage (default: llvm-link-14)
# export DG_LLVM_LINK_BINARY=llvm-link-14
# Extra args passed to llvm-slicer (default: -annotate slice)
# export DG_ARGS="-annotate slice"
# Extra native compile args for DG oracle (default: -O0 -Wall -Wextra)
# export DG_NATIVE_COMPILE_ARGS="-O0 -Wall -Wextra"

# --- CSmith (C program generator) ---
# CSmith installation root (must contain include/csmith.h and bin/csmith)
# export CSMITH_HOME=/usr
# Path to csmith binary (default: csmith, resolved from PATH)
# export CSMITH_BINARY=csmith
# Extra flags passed to csmith (space-separated)
# export CSMITH_USER_OPTIONS="--no-bitfields --max-block-depth 3 --max-block-size 4 --max-pointer-depth 2"
# CSmith headers directory (default: /usr/include/csmith)
export CSMITH_INCLUDE_DIR=/usr/include/csmith

# --- Creal (MR1 seed/mutant generator) ---
# Path to creal.py
export CREAL_SCRIPT=/path/to/creal/creal.py
# Python interpreter for running Creal (default: /usr/bin/python3)
# export CREAL_PYTHON=/usr/bin/python3

# --- mr_ast_tool (MR2/MR3 AST mutator) ---
# Build with: cmake -S tooling -B tooling/build && cmake --build tooling/build
export MR_AST_TOOL_BIN=/path/to/project/tooling/build/mr_ast_tool
# LLVM/Clang CMake package paths for building mr_ast_tool (defaults shown):
# export LLVM_DIR=/usr/lib/llvm-14/lib/cmake/llvm
# export Clang_DIR=/usr/lib/llvm-14/lib/cmake/clang

# --- Compile gate ---
# Clang binary for compile-check gate (default: /usr/lib/llvm-14/bin/clang)
# export CLANG_BIN=/usr/lib/llvm-14/bin/clang

# ============================================================================
# Optional: LLM Integration
# ============================================================================

# --- LLM online seed generation ---
# Command template with {prompt_file} and {output_file} placeholders.
# export LLM_COMMAND="python3 tooling/deepseek_client.py --prompt-file {prompt_file} --output-file {output_file}"

# --- LLM-assisted judge (DG hybrid/required mode) ---
# export DG_JUDGE_MODE=off
# Command template for LLM judge ({bundle_json} placeholder):
# export DG_LLM_JUDGE_COMMAND="python3 tooling/deepseek_judge.py --bundle {bundle_json} --output-dir /tmp/judge"

# --- DeepSeek API (used by both seed generation and judge) ---
# API key for DeepSeek API
# export DEEPSEEK_API_KEY=sk-your-key-here
# Base URL and model (defaults shown):
# export DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# export DEEPSEEK_MODEL=deepseek-v4-pro

# ============================================================================
# Optional: Bug Test Harnesses
# ============================================================================

# Path to DG experiments precision cases (test_dg_bugs.py, test_mr1_bug_detection.py)
# Default: ../dg-experiments/comfirm-issue/cases/precision relative to project
# export DG_EXPERIMENTS_CASES=/path/to/dg-experiments/comfirm-issue/cases/precision

# Path to Frama-C bug database (test_frama_bugs.py)
# Default: ../bugs/frama relative to project
# export FRAMA_BUGS_BASE=/path/to/project/bugs/frama
